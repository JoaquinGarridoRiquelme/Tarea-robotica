RectangleArena {
  floorSize 2 2
  floorTileSize 0.5 0.5
  floorAppearance PBRAppearance {
    baseColor 0.9 0.9 0.9
    roughness 1
    metalness 0
  }
  wallHeight 0.1
}

# ── Robot e-puck ─────────────────────────────
E-puck {
  translation 0 0 0
  rotation 0 0 1 0
  name "e-puck"
  controller "lab2_controller"
  groundSensorsSlot [
  ]
}

# ── Obstáculos simples (cajas) ───────────────

# Obstáculo 1 - frente
DEF BOX1 Solid {
  translation 0 0.5 0.05
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.8 0.2 0.2
        roughness 0.5
        metalness 0
      }
      geometry Box {
        size 0.15 0.15 0.1
      }
    }
  ]
  name "obstacle1"
  boundingObject Box {
    size 0.15 0.15 0.1
  }
  physics Physics {
    density -1
    mass 0.5
  }
}

